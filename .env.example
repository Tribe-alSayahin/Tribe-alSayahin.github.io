# إعداد Supabase — الواجهة (NEXT_PUBLIC_* تُحقن في كود المتصفح)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"

# إعداد Supabase — وقت البناء فقط (لا تُنشر في الواجهة)
# مفتاح service_role يُستخدم build-time لجلب الأخبار من Supabase أثناء next build
# احتفظ به في GitHub Actions Secrets فقط، ولا تضعه في NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# متغيرات اختيارية لبيئات التطوير المحلية
NEXT_PUBLIC_BING_VERIFICATION_CODE=""
NEXT_PUBLIC_YANDEX_VERIFICATION_CODE=""
