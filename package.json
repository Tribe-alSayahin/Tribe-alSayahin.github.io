{
  "name": "tribe-alsayahin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node -e \"const fs=require('fs'); if (!fs.existsSync('dist/404.html')) fs.copyFileSync('dist/index.html','dist/404.html')\"",
    "build:pages": "next build && node -e \"const fs=require('fs'); if (!fs.existsSync('dist/404.html')) fs.copyFileSync('dist/index.html','dist/404.html')\"", 
    "start": "npx serve dist -p 3000",
    "clean": "rm -rf dist .next",
    "lint": "tsc --noEmit && eslint src --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "vitest run"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/postcss": "^4.1.14",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.5.20",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.0.7",
    "axe-core": "^4.12.1",
    "esbuild": "^0.25.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.2.3",
    "vitest": "^3.0.7"
  }
}
